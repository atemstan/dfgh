#include <stdio.h>
#include <string.h>
int kiemtra(char words[][100],char table[][100], int a, int n, int m, int i){
    int t=0;
    int trangthai=0;
    for(int j=0;j<n;j++){
        for(int k=0;k<m-strlen(words[i])+1;k++){
            for(int l=0;l<strlen(words[i])-1;l++){
                if(words[i][l]==table[j][k+l]){
                    t++;
                    if(t==strlen(words[i])-1){
                        printf("%s %d %d 0 1\n",words[i], j,k);
                        trangthai=1;
                    }
                }
            }
            t=0;
        }
    }    
    for(int j=n-1;j>=0;j--){
        for(int k=m-1;k>=strlen(words[i])-2;k--){
            for(int l=0;l<strlen(words[i])-1;l++){
                if(words[i][l]==table[j][k-l]){             t++;
                    if(t==strlen(words[i])-1){
                         printf("%s %d %d 0 -1\n",words[i], j,k);
                         trangthai=1;
                    }
                }
            }
            t=0;
        }
    }
    
    for(int j=n-1;j>=0;j--){
        for(int k1=0,k2=0;k1<n&&k2<m;k1++,k2++){
            for(int l=0;l<strlen(words[i])-1;l++){
                if(words[i][l]==table[j+k1+l][k2+l]){       t++;
                    if(t==strlen(words[i])-1){
                         printf("%s %d %d 1 1\n",words[i], j+k1,k2);
                         trangthai=1;
                    }
                }
            }
            t=0;
        }
    }
    
    for(int j=0;j<n;j++){
        for(int k1=0,k2=0;k1<n&&k2<m;k1++,k2++){
            for(int l=0;l<strlen(words[i])-1;l++){
                if(words[i][l]==table[k1+l][j+k2+l]){       t++;
                    printf("%c", words[i][l]);
                    if(t==strlen(words[i])-1){
                         printf("%s %d %d 1 1\n",words[i], k1,j+k2);
                         trangthai=1;
                         
                    }
                }
            }
            t=0;
        }
    }
    return trangthai;


}
int main() {
   int n,m;
   char table[100][100];
   scanf("%d %d", &n,&m);
   for(int i=0;i<n;i++){
       for(int j=0;j<m;j++){
           scanf(" %c", &table[i][j]);
       }
   }
   int a=0;
   char words[100][100];
   while(1){
       scanf("%s", words[a]);
       if(strcmp(words[a],"#")==0){
           a++;
           break;
       }
       a++;
   }
   for(int i=0;i<a-1;i++){
       if(kiemtra(words,table,a,n,m,i)==0){
           printf("%s -1\n", words[i]);
       }
   }
   
}
