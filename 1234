#include <stdio.h>
#include <math.h>
#include <string.h>

struct sanpham{
    char madonhang[100];
    char tensanpham[100];
    int gia;
};


int main() {
    int n;
    struct sanpham sp[100];
    scanf("%d", &n);
    for(int i=0;i<n;i++){
        scanf("%s", sp[i].madonhang);
        scanf(" %[^\n]", sp[i].tensanpham);
        scanf("%d", &sp[i].gia);
    }
    
    
    return 0;
}
